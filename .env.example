APP_ENV=local
PORT=4000
NODE_ENV=development
ADMIN_AUTH_MODE=local
# Local/dev persistence uses SQLite through node:sqlite.
# Production/staging managed database target:
#   DATABASE_URL=postgresql://user:password@host:5432/database
#   PERSISTENCE_DRIVER=postgres
#   DATABASE_SSL=true
# The health readiness check blocks production readiness unless a managed DB URL is configured and the managed adapter is active.
# Optional integration validation:
#   TEST_MANAGED_DATABASE_URL=postgresql://user:password@host:5432/test_database
#   TEST_MANAGED_DATABASE_SSL=true
DATABASE_URL=file:./data/onboarding-local.db
# sqlite is the local/default active runtime adapter. postgres is the managed adapter target for production deployments.
PERSISTENCE_DRIVER=sqlite
DATABASE_SSL=false
PLATFORM_DATA_DIR=data
DEFAULT_TENANT_ID=tenant-acme
DEFAULT_TENANT_NAME=Acme Corp
DEFAULT_TENANT_REGION=us
SECONDARY_TENANT_ID=tenant-beta
SECONDARY_TENANT_NAME=Beta Industries
SECONDARY_TENANT_REGION=eu
VITE_DEFAULT_TENANT_ID=tenant-acme
VITE_SECONDARY_TENANT_ID=tenant-beta
KEYVAULT_URI=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
TEAMS_APP_ID=00000000-0000-0000-0000-000000000001
TEAMS_BOT_APP_ID=00000000-0000-0000-0000-000000000001
TEAMS_APP_DOMAIN=localhost:5173
BOT_ENDPOINT=http://localhost:4000/api/teams/messages
LICENSE_SECRET=local-dev-license-secret
LOG_LEVEL=debug
TELEMETRY_VERBOSE=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_WORKFLOW_MAX=60
RATE_LIMIT_AGENT_MAX=60
RATE_LIMIT_ADMIN_MAX=120
ACTIVATION_BASE_URL=http://localhost:5173
ACTIVATION_DELIVERY_MODE=log
ACTIVATION_EMAIL_PROVIDER=sendgrid
ACTIVATION_DELIVERY_WEBHOOK_URL=
ACTIVATION_DELIVERY_PREVIEW=true
ACTIVATION_SENDER_EMAIL=no-reply@localhost
ACTIVATION_SENDER_SMS=
SENDGRID_API_KEY=
# Set true only after the SendGrid sender/domain is verified in the SendGrid account.
SENDGRID_SENDER_VERIFIED=false
# Keep false in production unless volatile in-memory stores are intentionally accepted for a temporary validation environment.
ALLOW_VOLATILE_RUNTIME_STATE=false
CLICKUP_API_KEY=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
MONDAY_API_KEY=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=
